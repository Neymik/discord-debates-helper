    "prisma:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@debates/shared": "*",
    "@prisma/client": "^5.20.0",
    "archiver": "^7.0.1",
    "bullmq": "^5.13.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "ioredis": "^5.4.0",
    "jose": "^5.9.0",
    "node-cron": "^3.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0"
