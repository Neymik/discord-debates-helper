{
  "name": "discord-debates-helper",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b packages/shared packages/api packages/discord-bot",
    "test": "vitest run --no-file-parallelism",
    "test:watch": "vitest --no-file-parallelism"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0"
  },
  "overrides": {
    "ioredis": "5.11.0"
  }
}
